# OpenAI兼容协议LLM配置
# 请复制此文件为.env并填写正确的参数

# API基础URL
BASE_URL="http://127.0.0.1:1234"

# 模型名称
MODEL="qwen3.5-2b"

# API密钥
API_KEY="your-api-key-here"

# 温度参数（0-2，默认1）
TEMPERATURE=1

# 最大输出token数
MAX_TOKENS=512

# 超时时间（秒）
TIMEOUT=30

# AnythingLLM配置
ANYTHINGLLM_API_KEY="your_api_key_here"
ANYTHINGLLM_WORKSPACE_SLUG="your_workspace_slug"